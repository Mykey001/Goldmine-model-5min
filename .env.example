# Database Configuration
DATABASE_URL=postgres://avnadmin:password@pg-host.com:19738/defaultdb?sslmode=require

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=your_secret_key_change_this_in_production

# CORS Origins (comma separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Risk Management
MAX_DAILY_LOSS=400
MAX_POSITIONS=1
MIN_CONFIDENCE=0.5
DEFAULT_LOT_SIZE=0.01

# Trading Parameters
# For Gold (XAUUSD): 50 pips = 500 points = $5.00, 100 pips = 1000 points = $10.00
# For Forex: 50 pips = 5 points, 100 pips = 10 points
TP_PIPS=100           # Take profit in pips
SL_PIPS=50            # Stop loss in pips
# PIP_VALUE is auto-detected based on symbol:
# - Gold (XAUUSD): 0.1 per pip (1 pip = 10 points = $0.10, so 50 pips = $5.00)
# - Standard Forex (EUR/USD, GBP/USD, etc.): 0.0001 pip
# - JPY pairs (USD/JPY, EUR/JPY, etc.): 0.01 pip
# - Silver (XAGUSD): 0.001 pip
# - Indices: 1.0 or 0.1 depending on the index

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/live_trading.log

# Model Path
MODEL_PATH=models/final/xgboost_model.pkl
